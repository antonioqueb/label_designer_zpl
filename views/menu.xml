<odoo>
    <record id="action_label_templates" model="ir.actions.act_window">
        <field name="name">Plantillas ZPL</field>
        <field name="res_model">label.template</field>
        <!-- CAMBIO: tree,form por list,form -->
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_label_root" name="Impresión ZPL" sequence="10"/>
    <menuitem id="menu_label_templates" name="Plantillas" parent="menu_label_root" action="action_label_templates" sequence="10"/>

    <record id="action_label_designer_client" model="ir.actions.client">
        <field name="name">Diseñador Visual</field>
        <field name="tag">label_designer_zpl.designer</field>
        <field name="target">fullscreen</field>
    </record>
</odoo>